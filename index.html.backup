<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FarmFriend Marketplace - Agricultural AI Solutions</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Cormorant+Garamond:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css">
  <style>
    :root {
      --brand-primary: #4a7c59;
      --brand-primary-dark: #3d6b4a;
      --brand-primary-light: #6b9b7a;
      --brand-accent: #c4a35a;
      --earth-dark: #1a1814;
      --earth-mid: #2d2820;
      --earth-light: #3d3630;
      --cream: #f5f2ed;
      --text-light: #e8e4dd;
      --text-muted: #a8a198;
      --border-subtle: rgba(74, 124, 89, 0.2);
      --font-display: 'Cormorant Garamond', serif;
      --font-body: 'Space Grotesk', sans-serif;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      background: var(--earth-dark);
      color: var(--text-light);
      min-height: 100vh;
      overflow-x: hidden;
    }
    
    /* Navigation */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(26, 24, 20, 0.95);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border-subtle);
      max-width: 100%;
      overflow: hidden;
    }
    .logo {
      font-family: var(--font-display);
      font-size: 1.75rem;
      font-weight: 600;
      color: var(--brand-primary);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .logo-icon {
      width: 45px;
      height: 45px;
      object-fit: contain;
      border-radius: 12px;
    }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      color: var(--text-light);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      position: relative;
      transition: color 0.3s;
      cursor: pointer;
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--brand-primary);
      transition: width 0.3s;
    }
    .nav-links a:hover { color: var(--brand-primary); }
    .nav-links a:hover::after { width: 100%; }
    /* Search Bar */
    .search-box {
      position: relative;
      display: flex;
      align-items: center;
    }
    .search-input {
      background: rgba(255,255,255,0.1);
      border: 1px solid var(--border-subtle);
      border-radius: 8px;
      padding: 0.6rem 1rem 0.6rem 2.5rem;
      color: var(--text-light);
      font-family: var(--font-body);
      font-size: 0.9rem;
      width: 200px;
      transition: all 0.3s;
    }
    .search-input::placeholder {
      color: var(--text-muted);
    }
    .search-input:focus {
      outline: none;
      border-color: var(--brand-primary);
      background: rgba(255,255,255,0.15);
      width: 280px;
    }
    .search-icon {
      position: absolute;
      left: 0.75rem;
      color: var(--text-muted);
      pointer-events: none;
    }
    .nav-actions { display: flex; gap: 1rem; align-items: center; }
    
    .btn {
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      font-family: var(--font-body);
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.4s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border: none;
    }
    .btn-ghost {
      background: transparent;
      border: 2px solid var(--brand-primary);
      color: var(--brand-primary);
    }
    .btn-ghost:hover {
      background: var(--brand-primary);
      color: var(--earth-dark);
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-primary-dark));
      color: white;
      box-shadow: 0 4px 20px rgba(74, 124, 89, 0.4);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(74, 124, 89, 0.5);
    }
    
    /* Mobile Menu */
    .mobile-menu-btn {
      display: none;
      background: none;
      border: none;
      font-size: 1.5rem;
      color: var(--text-light);
      cursor: pointer;
      padding: 0.5rem;
      transition: color 0.3s;
    }
    .mobile-menu-btn:hover {
      color: var(--brand-primary);
    }
    .mobile-menu-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      z-index: 999;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }
    .mobile-menu-overlay.open {
      opacity: 1;
      pointer-events: auto;
    }
    .mobile-menu {
      position: fixed;
      top: 0;
      right: -300px;
      width: 300px;
      height: 100vh;
      background: var(--earth-mid);
      z-index: 1000;
      padding: 5rem 2rem 2rem;
      transition: right 0.3s;
      box-shadow: -5px 0 20px rgba(0,0,0,0.3);
    }
    .mobile-menu.open {
      right: 0;
    }
    .mobile-menu .nav-links {
      flex-direction: column;
      gap: 1.5rem;
    }
    .mobile-menu .nav-links a {
      font-size: 1.2rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border-subtle);
    }
    .mobile-menu-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      font-size: 1.5rem;
      color: var(--text-light);
      cursor: pointer;
    }
    @media (max-width: 1024px) {
      .nav { padding: 0.75rem 1rem; }
      .nav-links { display: none; }
      .mobile-menu-btn { display: block !important; }
      .mobile-hide { display: none; }
      .hero, .section { padding: 3rem 1rem; }
      .hero-content { padding: 0 1rem; }
      .featured-banner { grid-template-columns: 1fr; padding: 2rem; }
      .footer-content { grid-template-columns: 1fr 1fr; gap: 2rem; }
      .cart-sidebar { width: 100%; right: -100%; }
      .products-grid { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
      .categories-grid { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
      .hero h1 { font-size: clamp(2rem, 6vw, 3rem); }
      .hero-stats { gap: 2rem; }
    }
    
    /* Hero Section */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 7rem 2rem 3rem;
      background: linear-gradient(180deg, var(--earth-dark) 0%, var(--earth-mid) 50%, var(--earth-light) 100%);
      position: relative;
      overflow: hidden;
    }
    
    /* Animated Particles */
    .particles {
      position: absolute;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
    }
    .particle {
      position: absolute;
      width: 4px;
      height: 4px;
      background: var(--brand-primary);
      border-radius: 50%;
      opacity: 0.6;
      animation: float 15s infinite;
    }
    @keyframes float {
      0%, 100% {
        transform: translateY(100vh) rotate(0deg);
        opacity: 0;
      }
      10% { opacity: 0.6; }
      90% { opacity: 0.6; }
      100% {
        transform: translateY(-100vh) rotate(720deg);
        opacity: 0;
      }
    }
    
    /* Glow effects */
    .glow {
      position: absolute;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      filter: blur(100px);
      opacity: 0.3;
    }
    .glow-1 {
      top: -100px;
      left: -100px;
      background: var(--brand-primary);
      animation: pulse 8s ease-in-out infinite;
    }
    .glow-2 {
      bottom: -150px;
      right: -100px;
      background: var(--brand-primary-dark);
      animation: pulse 10s ease-in-out infinite reverse;
    }
    @keyframes pulse {
      0%, 100% { opacity: 0.3; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.1); }
    }
    
    .hero-content {
      max-width: 900px;
      text-align: center;
      position: relative;
      z-index: 10;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.6rem 1.25rem;
      background: rgba(74, 124, 89, 0.15);
      border: 2px solid var(--brand-primary);
      border-radius: 50px;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 2rem;
      color: var(--brand-primary-light);
      font-weight: 500;
    }
    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(3rem, 8vw, 5.5rem);
      font-weight: 600;
      line-height: 1.05;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
      color: white;
      text-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
    }
    .hero h1 span {
      color: var(--brand-primary);
    }
    .hero-description {
      font-size: 1.3rem;
      line-height: 1.7;
      color: var(--text-muted);
      max-width: 650px;
      margin: 0 auto 2.5rem;
    }
    .hero-cta {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 3rem;
    }
    .hero-stats {
      display: flex;
      justify-content: center;
      gap: 4rem;
      flex-wrap: wrap;
    }
    .stat {
      text-align: center;
    }
    .stat-value {
      font-family: var(--font-display);
      font-size: 2.5rem;
      font-weight: 600;
      color: var(--brand-primary);
    }
    .stat-label {
      font-size: 0.85rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-top: 0.25rem;
    }
    
    /* Sections */
    .section {
      padding: 6rem 4rem;
      position: relative;
    }
    .section-dark {
      background: var(--earth-mid);
    }
    .section-light {
      background: var(--earth-light);
    }
    .section-header {
      text-align: center;
      margin-bottom: 4rem;
    }
    .section-label {
      font-size: 0.85rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--brand-primary-light);
      margin-bottom: 1rem;
      font-weight: 600;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 600;
      color: white;
    }
    
    /* Cards */
    .glass-card {
      background: rgba(45, 40, 32, 0.6);
      backdrop-filter: blur(20px);
      border: 1px solid var(--border-subtle);
      border-radius: 20px;
      padding: 2rem;
      transition: all 0.5s;
      cursor: pointer;
    }
    .glass-card:hover {
      transform: translateY(-8px);
      border-color: var(--brand-primary);
      box-shadow: 0 20px 40px rgba(74, 124, 89, 0.2);
    }
    
    .category-card {
      background: rgba(45, 40, 32, 0.6);
      backdrop-filter: blur(20px);
      border: 1px solid var(--border-subtle);
      border-radius: 20px;
      padding: 2rem;
      cursor: pointer;
      transition: all 0.5s;
    }
    .category-card:hover {
      transform: translateY(-8px);
      border-color: var(--brand-primary);
      box-shadow: 0 20px 40px rgba(74, 124, 89, 0.2);
    }
    .category-icon {
      width: 65px;
      height: 65px;
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-primary-dark));
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.75rem;
      margin-bottom: 1.5rem;
    }
    .category-name {
      font-family: var(--font-display);
      font-size: 1.5rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: white;
    }
    .category-description {
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.6;
    }
    .category-count {
      display: inline-block;
      font-size: 0.75rem;
      color: var(--brand-primary-light);
      background: rgba(74, 124, 89, 0.15);
      padding: 0.3rem 0.75rem;
      border-radius: 20px;
      font-weight: 500;
      margin-top: 1rem;
    }
    
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      max-width: 1400px;
      margin: 0 auto;
    }
    
    /* Product Cards */
    .product-card {
      background: rgba(45, 40, 32, 0.6);
      backdrop-filter: blur(20px);
      border: 1px solid var(--border-subtle);
      border-radius: 24px;
      overflow: hidden;
      transition: all 0.5s;
      cursor: pointer;
    }
    .product-card:hover {
      transform: translateY(-8px);
      border-color: var(--brand-primary);
      box-shadow: 0 25px 50px rgba(74, 124, 89, 0.2);
    }
    .product-image {
      height: 200px;
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-primary-dark));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 4.5rem;
      position: relative;
    }
    .product-badge {
      position: absolute;
      top: 1rem;
      left: 1rem;
      background: var(--brand-accent);
      color: var(--earth-dark);
      padding: 0.35rem 0.85rem;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      z-index: 1;
    }
    .product-content {
      padding: 1.5rem;
    }
    .product-sku {
      font-size: 0.75rem;
      color: var(--brand-primary-light);
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }
    .product-name {
      font-family: var(--font-display);
      font-size: 1.35rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      line-height: 1.3;
      color: white;
    }
    .product-description {
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.6;
      margin-bottom: 1rem;
    }
    .product-features {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1.25rem;
    }
    .feature-tag {
      background: rgba(74, 124, 89, 0.15);
      color: var(--brand-primary-light);
      padding: 0.3rem 0.7rem;
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 500;
    }
    .product-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 1rem;
      border-top: 1px solid var(--border-subtle);
    }
    .product-price {
      font-family: var(--font-display);
      font-size: 1.6rem;
      font-weight: 600;
      color: var(--brand-primary);
    }
    .product-price-period {
      font-size: 0.75rem;
      font-weight: 400;
      color: var(--text-muted);
      margin-left: 0.25rem;
      display: inline-block;
      vertical-align: middle;
      opacity: 0.8;
    }
    
    .btn-add {
      padding: 0.7rem 1.4rem;
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-primary-dark));
      border: none;
      border-radius: 8px;
      color: white;
      font-family: var(--font-body);
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.3s;
    }
    .btn-add:hover {
      transform: scale(1.05);
      box-shadow: 0 6px 20px rgba(74, 124, 89, 0.4);
    }
    
    .products-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2rem;
      max-width: 1400px;
      margin: 0 auto;
    }
    
    /* Featured Banner */
    .featured-banner {
      max-width: 1400px;
      margin: 0 auto;
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-primary-dark));
      border-radius: 32px;
      padding: 4rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      position: relative;
      overflow: hidden;
    }
    .featured-banner::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -20%;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(255,255,255,0.15), transparent 70%);
    }
    .featured-content {
      position: relative;
      z-index: 1;
    }
    .featured-label {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255,255,255,0.2);
      padding: 0.5rem 1rem;
      border-radius: 30px;
      font-size: 0.85rem;
      margin-bottom: 1.5rem;
      color: white;
    }
    .featured-label i {
      color: var(--brand-accent);
    }
    .featured h2 {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 600;
      margin-bottom: 1rem;
      color: white;
    }
    .featured p {
      font-size: 1.1rem;
      line-height: 1.7;
      opacity: 0.9;
      margin-bottom: 2rem;
    }
    .btn-white {
      background: white;
      color: var(--brand-primary-dark);
      padding: 1rem 2rem;
      border-radius: 8px;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
      transition: all 0.3s;
    }
    .btn-white:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }
    
    /* Footer */
    .footer {
      padding: 4rem;
      background: var(--earth-mid);
      border-top: 1px solid var(--border-subtle);
      color: white;
    }
    .footer-content {
      max-width: 1400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 2fr repeat(3, 1fr);
      gap: 4rem;
    }
    .footer-brand p {
      font-size: 0.95rem;
      color: var(--text-muted);
      margin-top: 1rem;
      line-height: 1.7;
    }
    .footer-title {
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--brand-primary-light);
      margin-bottom: 1.5rem;
      font-weight: 600;
    }
    .footer-links {
      list-style: none;
    }
    .footer-links li {
      margin-bottom: 0.75rem;
    }
    .footer-links a {
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.95rem;
      transition: color 0.3s;
    }
    .footer-links a:hover {
      color: var(--brand-primary);
    }
    .footer-bottom {
      max-width: 1400px;
      margin: 3rem auto 0;
      padding-top: 2rem;
      border-top: 1px solid var(--border-subtle);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .payment-methods {
      display: flex;
      gap: 1rem;
      align-items: center;
    }
    .payment-methods span {
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    .payment-icons {
      display: flex;
      gap: 0.75rem;
    }
    .payment-icon {
      width: 45px;
      height: 30px;
      background: rgba(255,255,255,0.1);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.65rem;
      font-weight: 600;
      color: white;
    }
    
    /* Cart Sidebar */
    .cart-sidebar {
      position: fixed;
      top: 0;
      right: -450px;
      width: 450px;
      height: 100vh;
      z-index: 2000;
      background: var(--earth-mid);
      box-shadow: -10px 0 40px rgba(0,0,0,0.3);
      transition: right 0.4s;
      display: flex;
      flex-direction: column;
    }
    .cart-sidebar.open {
      right: 0;
    }
    .cart-header {
      padding: 1.5rem;
      border-bottom: 1px solid var(--border-subtle);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .cart-header h3 {
      font-family: var(--font-display);
      font-size: 1.5rem;
      color: white;
    }
    .cart-close {
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--text-muted);
    }
    .cart-items {
      flex: 1;
      overflow-y: auto;
      padding: 1.5rem;
    }
    .cart-empty {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--text-muted);
    }
    .cart-empty i {
      font-size: 3rem;
      margin-bottom: 1rem;
      opacity: 0.3;
    }
    .cart-item {
      display: flex;
      gap: 1rem;
      padding: 1rem;
      background: rgba(45, 40, 32, 0.6);
      border-radius: 12px;
      margin-bottom: 1rem;
    }
    .cart-item-image {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-primary-dark));
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }
    .cart-item-details {
      flex: 1;
    }
    .cart-item-name {
      font-weight: 600;
      color: white;
      margin-bottom: 0.25rem;
      font-size: 0.9rem;
    }
    .cart-item-sku {
      font-size: 0.7rem;
      color: var(--brand-primary-light);
      margin-bottom: 0.25rem;
    }
    .cart-item-price {
      color: var(--brand-primary);
      font-weight: 600;
    }
    .cart-item-qty {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }
    .qty-btn {
      width: 28px;
      height: 28px;
      border: 1px solid var(--border-subtle);
      background: rgba(45, 40, 32, 0.6);
      border-radius: 6px;
      cursor: pointer;
      font-size: 1rem;
      color: var(--brand-primary);
    }
    .qty-value {
      font-weight: 600;
      min-width: 30px;
      text-align: center;
      color: white;
    }
    .cart-item-remove {
      background: none;
      border: none;
      color: #c97a7a;
      cursor: pointer;
      font-size: 0.9rem;
    }
    .cart-footer {
      padding: 1.5rem;
      border-top: 1px solid var(--border-subtle);
      background: rgba(45, 40, 32, 0.6);
    }
    .cart-total {
      display: flex;
      justify-content: space-between;
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 1rem;
      padding-top: 0.5rem;
      border-top: 1px solid var(--border-subtle);
      color: white;
    }
    .cart-total-price {
      color: var(--brand-primary);
      font-family: var(--font-display);
      font-size: 1.5rem;
    }
    .checkout-buttons {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .btn-paypal {
      background: #003087;
      color: white;
      padding: 1rem;
      border-radius: 8px;
      text-align: center;
      text-decoration: none;
      font-weight: 600;
      transition: all 0.3s;
    }
    .btn-stripe {
      background: #635bff;
      color: white;
      padding: 1rem;
      border-radius: 8px;
      text-align: center;
      text-decoration: none;
      font-weight: 600;
      transition: all 0.3s;
    }
    
    /* Product Modal */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      z-index: 1500;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }
    .modal-overlay.open {
      opacity: 1;
      pointer-events: auto;
    }
    .modal {
      background: var(--earth-mid);
      border-radius: 24px;
      max-width: 700px;
      width: 90%;
      max-height: 90vh;
      overflow-y: auto;
      transform: scale(0.9);
      transition: transform 0.3s;
      border: 1px solid var(--border-subtle);
    }
    .modal-overlay.open .modal {
      transform: scale(1);
    }
    .modal-header {
      padding: 2rem 2rem 0;
      position: relative;
    }
    .modal-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--text-muted);
    }
    .modal-badge {
      display: inline-block;
      background: var(--brand-accent);
      color: var(--earth-dark);
      padding: 0.35rem 0.85rem;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .modal-sku {
      font-size: 0.8rem;
      color: var(--brand-primary-light);
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
    }
    .modal-title {
      font-family: var(--font-display);
      font-size: 2rem;
      font-weight: 600;
      margin-bottom: 1rem;
      color: white;
    }
    .modal-image {
      height: 250px;
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-primary-dark));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 6rem;
      margin: 1rem 2rem;
      border-radius: 16px;
    }
    .modal-body {
      padding: 0 2rem 2rem;
    }
    .modal-description {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }
    .modal-features {
      margin-bottom: 1.5rem;
    }
    .modal-features h4 {
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: white;
    }
    .modal-features li {
      padding: 0.5rem 0;
      padding-left: 1.5rem;
      position: relative;
      font-size: 0.9rem;
      color: var(--text-muted);
      list-style: none;
    }
    .modal-features li::before {
      content: '\2713';
      position: absolute;
      left: 0;
      color: var(--brand-primary);
      font-weight: 600;
    }
    .modal-footer {
      padding: 1.5rem 2rem;
      border-top: 1px solid var(--border-subtle);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      background: rgba(45, 40, 32, 0.6);
      border-radius: 0 0 24px 24px;
    }
    .modal-price {
      font-family: var(--font-display);
      font-size: 2rem;
      font-weight: 600;
      color: var(--brand-primary);
    }
    .modal-actions {
      display: flex;
      gap: 1rem;
    }
    .btn-modal-close {
      padding: 1rem 1.5rem;
      background: transparent;
      border: 2px solid var(--border-subtle);
      border-radius: 8px;
      color: var(--text-muted);
      font-family: var(--font-body);
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
    }
    .btn-modal-add {
      padding: 1rem 2rem;
      background: linear-gradient(135deg, var(--brand-primary), var(--brand-primary-dark));
      border: none;
      border-radius: 8px;
      color: white;
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
    }
    
    .reveal {
      opacity: 1;
      transform: translateY(0);
    }
    
    .cart-notification {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      background: var(--brand-primary);
      color: white;
      padding: 1rem 1.5rem;
      border-radius: 12px;
      box-shadow: 0 10px 30px rgba(74, 124, 89, 0.4);
      z-index: 3000;
      transform: translateY(100px);
      opacity: 0;
      transition: all 0.4s;
    }
    .cart-notification.show {
      transform: translateY(0);
      opacity: 1;
    }
    
    @media (max-width: 1024px) {
      .nav { padding: 0.75rem 1rem; }
      .nav-links { display: none; }
      .hero, .section { padding: 3rem 1rem; }
      .hero-content { padding: 0 1rem; }
      .featured-banner { grid-template-columns: 1fr; padding: 2rem; }
      .footer-content { grid-template-columns: 1fr 1fr; gap: 2rem; }
      .cart-sidebar { width: 100%; right: -100%; }
      .products-grid { grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
      .categories-grid { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
      .hero h1 { font-size: clamp(2rem, 6vw, 3rem); }
      .hero-stats { gap: 2rem; }
    }
    @media (max-width: 640px) {
      body { overflow-x: hidden; }
      .nav { padding: 0.5rem 0.75rem; }
      .logo-text { display: none; }
      .logo { font-size: 1.25rem; }
      .search-box { display: none; }
      .hero-stats { flex-direction: column; gap: 1.5rem; }
      .hero-cta { flex-direction: column; }
      .hero-cta .btn { width: 100%; justify-content: center; }
      .footer-content { grid-template-columns: 1fr; text-align: center; }
      .footer-bottom { flex-direction: column; text-align: center; }
      .modal-footer { flex-direction: column; }
      .modal-actions { width: 100%; }
      .modal-actions button { width: 100%; }
      .section-header { margin-bottom: 2rem; }
      .section-title { font-size: 1.75rem; }
      .glass-card { padding: 1.25rem; }
      .product-card { margin: 0 -0.5rem; }
      .product-content { padding: 1rem; }
      .hero-description { font-size: 1rem; padding: 0 0.5rem; }
      .footer { padding: 2rem 1rem; }
      .categories-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <!-- Particles -->
  <div class="particles" id="particles"></div>
  <div class="glow glow-1"></div>
  <div class="glow glow-2"></div>
  
  <nav class="nav">
    <a href="#" class="logo">
      <img src="assets/fft-logo.jpg" alt="FarmFriend Logo" class="logo-icon" style="width:45px;height:45px;border-radius:12px;">
      <span class="logo-text">FarmFriend</span>
    </a>
    
    <!-- Mobile Menu Button -->
    <button class="mobile-menu-btn" id="mobileMenuBtn" onclick="toggleMobileMenu()">
      <i class="fas fa-bars"></i>
    </button>
    
    <ul class="nav-links" id="navLinks">
      <li><a href="#categories" onclick="scrollToSection('categories')">Products</a></li>
      <li><a href="#hardware" onclick="scrollToSection('hardware')">Hardware</a></li>
      <li><a href="#skills" onclick="scrollToSection('skills')">Skills</a></li>
      <li><a href="#services" onclick="scrollToSection('services')">Services</a></li>
      <li><a href="#data" onclick="scrollToSection('data')">Data</a></li>
    </ul>
    <div class="nav-actions">
      <div class="search-box">
        <i class="fas fa-search search-icon"></i>
        <input type="text" class="search-input" placeholder="Search products..." id="searchInput">
      </div>
      <button class="btn btn-ghost" id="cartBtn"><i class="fas fa-shopping-cart"></i><span id="cartCount">0</span></button>
      <button class="btn btn-primary mobile-hide" onclick="scrollToSection('categories')"><i class="fas fa-rocket"></i>Explore Marketplace</button>
    </div>
  </nav>
  
  <!-- Mobile Menu Overlay -->
  <div class="mobile-menu-overlay" id="mobileMenuOverlay" onclick="toggleMobileMenu()"></div>
  
  <!-- Mobile Menu Sidebar -->
  <div class="mobile-menu" id="mobileMenu">
    <button class="mobile-menu-close" onclick="toggleMobileMenu()"><i class="fas fa-times"></i></button>
    <ul class="nav-links">
      <li><a href="#categories" onclick="toggleMobileMenu(); scrollToSection('categories')">Products</a></li>
      <li><a href="#hardware" onclick="toggleMobileMenu(); scrollToSection('hardware')">Hardware</a></li>
      <li><a href="#skills" onclick="toggleMobileMenu(); scrollToSection('skills')">Skills</a></li>
      <li><a href="#services" onclick="toggleMobileMenu(); scrollToSection('services')">Services</a></li>
      <li><a href="#data" onclick="toggleMobileMenu(); scrollToSection('data')">Data</a></li>
      <li><a href="#newsletter" onclick="toggleMobileMenu()">Newsletter</a></li>
      <li><a href="#support" onclick="toggleMobileMenu()">Support</a></li>
      <li><a href="#consulting" onclick="toggleMobileMenu()">Consulting</a></li>
    </ul>
  </div>
  
  <section class="hero">
    <div class="hero-content">
      <div class="hero-badge"><i class="fas fa-leaf"></i>FFT_nano Powered</div>
      <h1>The Future of <span>Agricultural Intelligence</span></h1>
      <p class="hero-description">Discover premium hardware, AI skills, and services for your farm. Powered by FFT_nano edge AI agents that learn, adapt, and grow with your operation.</p>
      <div class="hero-cta">
        <button class="btn btn-primary" onclick="scrollToSection('categories')"><i class="fas fa-compass"></i>Explore Marketplace</button>
        <button class="btn btn-ghost" onclick="scrollToSection('services')"><i class="fas fa-calendar"></i>Book Consultation</button>
      </div>
      <div class="hero-stats">
        <div class="stat"><div class="stat-value">50+</div><div class="stat-label">Products</div></div>
        <div class="stat"><div class="stat-value">8</div><div class="stat-label">Categories</div></div>
        <div class="stat"><div class="stat-value">23</div><div class="stat-label">Services & Support</div></div>
      </div>
    </div>
  </section>
  
  <!-- About FFT_nano Section -->
  <section class="section" id="about">
    <div class="section-header reveal">
      <div class="section-label">What is FFT_nano?</div>
      <h2 class="section-title">Edge-Native AI for Modern Agriculture</h2>
    </div>
    <div style="max-width: 900px; margin: 0 auto; text-align: center;">
      <p style="font-size: 1.15rem; line-height: 1.8; color: var(--text-muted); margin-bottom: 2rem;">
        FFT_nano is a lightweight, edge-native AI system that runs directly on your farm hardware. 
        Unlike cloud-based solutions, FFT_nano processes data locally — keeping your information private 
        and working even without internet connectivity.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; margin-top: 3rem;">
        <div class="glass-card" style="text-align: center; padding: 2rem;">
          <i class="fas fa-brain" style="font-size: 2.5rem; color: var(--brand-primary); margin-bottom: 1rem;"></i>
          <h4 style="color: white; margin-bottom: 0.5rem;">Smart & Adaptive</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">AI skills that learn your farm's unique patterns</p>
        </div>
        <div class="glass-card" style="text-align: center; padding: 2rem;">
          <i class="fas fa-wifi" style="font-size: 2.5rem; color: var(--brand-primary); margin-bottom: 1rem;"></i>
          <h4 style="color: white; margin-bottom: 0.5rem;">Works Offline</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Full functionality without internet dependency</p>
        </div>
        <div class="glass-card" style="text-align: center; padding: 2rem;">
          <i class="fas fa-shield-alt" style="font-size: 2.5rem; color: var(--brand-primary); margin-bottom: 1rem;"></i>
          <h4 style="color: white; margin-bottom: 0.5rem;">Private & Secure</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Your data stays on your farm, always</p>
        </div>
        <div class="glass-card" style="text-align: center; padding: 2rem;">
          <i class="fas fa-sync-alt" style="font-size: 2.5rem; color: var(--brand-primary); margin-bottom: 1rem;"></i>
          <h4 style="color: white; margin-bottom: 0.5rem;">Cloud Optional</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Sync to cloud when you need it</p>
        </div>
      </div>
    </div>
  </section>
  
  <section class="section section-dark" id="categories">
    <div class="section-header reveal">
      <div class="section-label">Browse</div>
      <h2 class="section-title">Shop by Category</h2>
    </div>
    <div class="categories-grid">
      <div class="category-card reveal" onclick="scrollToSection('hardware')">
        <div class="category-icon"><i class="fas fa-microchip"></i></div>
        <h3 class="category-name">Hardware Kits</h3>
        <p class="category-description">Pre-configured farm computing systems from starter to enterprise.</p>
        <span class="category-count">10 items</span>
      </div>
      <div class="category-card reveal" onclick="scrollToSection('skills')">
        <div class="category-icon"><i class="fas fa-brain"></i></div>
        <h3 class="category-name">Skills & Extensions</h3>
        <p class="category-description">AI-powered skills for weather, irrigation, pest detection, and more.</p>
        <span class="category-count">15 items</span>
      </div>
      <div class="category-card reveal" onclick="scrollToSection('services')">
        <div class="category-icon"><i class="fas fa-cogs"></i></div>
        <h3 class="category-name">Setup Services</h3>
        <p class="category-description">Guided installation, migration, and configuration services.</p>
        <span class="category-count">7 items</span>
      </div>
      <div class="category-card reveal" onclick="scrollToSection('support')">
        <div class="category-icon"><i class="fas fa-life-ring"></i></div>
        <h3 class="category-name">Support Plans</h3>
        <p class="category-description">From community forums to enterprise SLA support.</p>
        <span class="category-count">4 items</span>
      </div>
      <div class="category-card reveal" onclick="scrollToSection('cloud')">
        <div class="category-icon"><i class="fas fa-cloud"></i></div>
        <h3 class="category-name">Cloud Services</h3>
        <p class="category-description">Sync, backup, API access, and enhanced AI models.</p>
        <span class="category-count">8 items</span>
      </div>
      <div class="category-card reveal" onclick="scrollToSection('education')">
        <div class="category-icon"><i class="fas fa-graduation-cap"></i></div>
        <h3 class="category-name">Education</h3>
        <p class="category-description">Courses, certifications, and workshops for all skill levels.</p>
        <span class="category-count">6 items</span>
      </div>
      <div class="category-card reveal" onclick="scrollToSection('consulting')">
        <div class="category-icon"><i class="fas fa-handshake"></i></div>
        <h3 class="category-name">Consulting</h3>
        <p class="category-description">Custom development, integrations, and strategic planning.</p>
        <span class="category-count">6 items</span>
      </div>
      <div class="category-card reveal" onclick="scrollToSection('data')">
        <div class="category-icon"><i class="fas fa-chart-bar"></i></div>
        <h3 class="category-name">Data Products</h3>
        <p class="category-description">Weather, soil, yield benchmarks, and market insights.</p>
        <span class="category-count">8 items</span>
      </div>
    </div>
  </section>
  
  <!-- Featured Bundle -->
  <section class="section">
    <div class="featured-banner reveal">
      <div class="featured-content">
        <div class="featured-label"><i class="fas fa-star"></i>Limited Time Offer</div>
        <h2>Starter Farm Bundle</h2>
        <p>Everything you need to get started with FFT_nano on your farm. Includes Nano kit, Weather skill, and 1 hour of guided setup.</p>
        <a href="#hardware" class="btn-white"><i class="fas fa-shopping-cart"></i>Shop the Bundle</a>
      </div>
    </div>
  </section>
  
  <!-- Hardware Section -->
  <section class="section section-light" id="hardware">
    <div class="section-header reveal">
      <div class="section-label">Hardware</div>
      <h2 class="section-title">Hardware Solutions</h2>
    </div>
    <div class="products-grid" id="hardware-grid">

          <div class="product-card">
            <div class="product-image">
              <span class="product-badge">Popular</span>
              <i class="fas fa-desktop"></i>
            </div>
            <div class="product-content">
              <div class="product-sku">HW-NANO-KIT</div>
              <h3 class="product-name">FarmFriend Nano Starter Kit</h3>
              <p class="product-description">Complete Raspberry Pi 5 system for small farms. Pre-configured and ready to deploy.</p>
              <div class="product-features">
                <span class="feature-tag">Pi 5 8GB</span><span class="feature-tag">256GB SSD</span><span class="feature-tag">FFT_nano Pre-installed</span>
              </div>
              <div class="product-footer">
                <div class="product-price">$249<span class="product-price-period"></span></div>
                <button class="btn-add" onclick="event.stopPropagation(); addToCart('HW-NANO-KIT')">Add to Cart</button>
              </div>
            </div>
          </div>
          <div class="product-card">
            <div class="product-image">
              <span class="product-badge">Pro</span>
              <i class="fas fa-server"></i>
            </div>
            <div class="product-content">
              <div class="product-sku">HW-PRO-KIT</div>
              <h3 class="product-name">FarmFriend Pro Deployment Kit</h3>
              <p class="product-description">Professional-grade system for medium to large farms with cellular backup.</p>
              <div class="product-features">
                <span class="feature-tag">Pi 5 16GB</span><span class="feature-tag">512GB NVMe SSD</span><span class="feature-tag">LTE Cellular Backup</span>
              </div>
              <div class="product-footer">
                <div class="product-price">$599<span class="product-price-period"></span></div>
                <button class="btn-add" onclick="event.stopPropagation(); addToCart('HW-PRO-KIT')">Add to Cart</button>
              </div>
            </div>
          </div>
          <div class="product-card">
            <div class="product-image">
              <span class="product-badge">Enterprise</span>
              <i class="fas fa-building"></i>
            </div>
            <div class="product-content">
              <div class="product-sku">HW-ENT-KIT</div>
              <h3 class="product-name">FarmFriend Enterprise Kit</h3>
              <p class="product-description">Multi-site deployment system for large agricultural operations.</p>
              <div class="product-features">
                <span class="feature-tag">Pi 5 32GB</span><span class="feature-tag">1TB NVMe</span><span class="feature-tag">Dual LTE</span>
              </div>
              <div class="product-footer">
                <div class="product-price">$1499<span class="product-price-period"></span></div>
                <button class="btn-add" onclick="event.stopPropagation(); addToCart('HW-ENT-KIT')">Add to Cart</button>
              </div>
            </div>
          </div>
          <div class="product-card">
            <div class="product-image">
              
              <i class="fas fa-microchip"></i>
            </div>
            <div class="product-content">
              <div class="product-sku">HW-RPI5-8G</div>
              <h3 class="product-name">Pre-configured Raspberry Pi 5 8GB</h3>
              <p class="product-description">Just the Pi - pre-flashed with FFT_nano for DIY installations.</p>
              <div class="product-features">
                <span class="feature-tag">Pi 5 8GB</span><span class="feature-tag">256GB SD Card</span><span class="feature-tag">FFT_nano Lite</span>
              </div>
              <div class="product-footer">
                <div class="product-price">$189<span class="product-price-period"></span></div>
                <button class="btn-add" onclick="event.stopPropagation(); addToCart('HW-RPI5-8G')">Add to Cart</button>
              </div>
            </div>
          </div>
          <div class="product-card">
            <div class="product-image">
              
              <i class="fas fa-box"></i>
            </div>
            <div class="product-content">
              <div class="product-sku">HW-ENC-IND</div>
              <h3 class="product-name">Industrial Enclosure (IP67)</h3>
              <p class="product-description">Weatherproof enclosure for harsh farm environments.</p>
              <div class="product-features">
                <span class="feature-tag">IP67 Rated</span><span class="feature-tag">Temperature Controlled</span><span class="feature-tag">Lockable</span>
              </div>
              <div class="product-footer">
                <div class="product-price">$349<span class="product-price-period"></span></div>
                <button class="btn-add" onclick="event.stopPropagation(); addToCart('HW-ENC-IND')">Add to Cart</button>
              </div>
            </div>
          </div>
          <div class="product-card">
            <div class="product-image">
              
              <i class="fas fa-solar-panel"></i>
            </div>
            <div class="product-content">
              <div class="product-sku">HW-SOLAR-KIT</div>
              <h3 class="product-name">Solar Power Kit (Remote)</h3>
              <p class="product-description">Complete solar power solution for remote sensor deployments.</p>
              <div class="product-features">
                <span class="feature-tag">100W Panel</span><span class="feature-tag">Charge Controller</span><span class="feature-tag">Battery Pack</span>
              </div>
              <div class="product-footer">
