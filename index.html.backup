        { sku: 'EDU-101', name: 'FFT_nano Fundamentals', price: 0, badge: 'Free', icon: 'fa-book-open', description: 'Free documentation and getting started guides.', features: ['Core Concepts', 'Setup Guide', 'Best Practices', 'Examples'], period: '', category: 'education' },
        { sku: 'EDU-VIDEO', name: 'Running Your Farm with AI (Video)', price: 49, badge: '', icon: 'fa-video', description: '8-module video course on AI-powered farming.', features: ['8 Video Modules', 'Downloadable Resources', 'Certificate of Completion'], period: '', category: 'education' },
        { sku: 'EDU-CERT-ADMIN', name: 'Certification: FarmFriend Administrator', price: 199, badge: '', icon: 'fa-certificate', description: 'Become a certified FarmFriend Administrator.', features: ['Exam (2 hours)', 'Lab Components', 'Digital Certificate', 'Admin Privileges'], period: '', category: 'education' },
        { sku: 'EDU-LIVE', name: 'Live Workshop Series', price: 29, badge: '', icon: 'fa-chalkboard-teacher', description: 'Monthly live workshops with Q&A and hands-on exercises.', features: ['Monthly Sessions', 'Live Q&A', 'Hands-On Labs', 'Recording Access'], period: '/month', category: 'education' },
        { sku: 'EDU-PRIVATE', name: 'Private Training (Up to 10 people)', price: 999, badge: '', icon: 'fa-users-cog', description: 'Custom on-site or virtual training for your team.', features: ['Custom Curriculum', 'Up to 10 Attendees', 'Hands-On Training', 'Q&A Session'], period: '', category: 'education' }
      ],
      consulting: [
        { sku: 'CON-DISCOVERY', name: 'Discovery Call (30min)', price: 0, badge: 'Free', icon: 'fa-phone-alt', description: 'Free consultation to discuss your farm needs.', features: ['No Obligation', 'Expert Advice', 'Needs Assessment', 'Recommendations'], period: '', category: 'consulting' },
        { sku: 'CON-AUDIT', name: 'Farm Process Audit', price: 499, badge: '', icon: 'fa-search', description: 'Comprehensive audit of your farm processes and technology.', features: ['On-Site/Remote Audit', 'Process Mapping', 'Gap Analysis', 'Improvement Plan'], period: '', category: 'consulting' },
        { sku: 'CON-INTEGRATE', name: 'Custom Integration Design', price: 1499, badge: '', icon: 'fa-plug', description: 'Design and implement custom integrations with your systems.', features: ['System Analysis', 'Integration Design', 'Implementation', 'Testing & Documentation'], period: '', category: 'consulting' },
        { sku: 'CON-SKILL-DEV', name: 'Custom Skill Development', price: 2999, badge: '', icon: 'fa-code-branch', description: 'Build custom AI skills tailored to your specific farm operations.', features: ['Custom Development', 'Testing', 'Deployment', 'Documentation'], period: 'per skill', category: 'consulting' },
        { sku: 'CON-ARCH', name: 'Full System Architecture', price: 4999, badge: '', icon: 'fa-sitemap', description: 'Complete system architecture design for large deployments.', features: ['Requirements Analysis', 'Architecture Design', 'Scalability Planning', 'Implementation Roadmap'], period: '', category: 'consulting' },
        { sku: 'CON-FRACTO', name: 'Fractional CTO Retainer', price: 3999, badge: '', icon: 'fa-user-tie', description: 'Ongoing strategic guidance from a Fractional CTO.', features: ['Monthly Retainer', 'Strategic Planning', 'Technical Leadership', 'Quarterly Reviews'], period: '/month', category: 'consulting' }
      ],
      data: [
        { sku: 'DATA-WEATHER', name: 'Local Weather Station (API)', price: 0, badge: 'Free', icon: 'fa-thermometer', description: 'Free local weather data via API integration.', features: ['Temperature', 'Humidity', 'Wind Speed', 'Basic Forecast'], period: '', category: 'data' },
        { sku: 'DATA-WEATHER-REG', name: 'Regional Weather Insights', price: 5, badge: '', icon: 'fa-cloud', description: 'Extended regional weather data and insights.', features: ['Hourly Updates', 'Regional Data', 'Historical Trends', 'Export Options'], period: '/month', category: 'data' },
        { sku: 'DATA-SOIL', name: 'Soil Type & Health Maps', price: 19, badge: '', icon: 'fa-map', description: 'Detailed soil analysis and health mapping for your property.', features: ['Soil Type Mapping', 'Health Assessment', 'Recommendation Engine', 'Seasonal Updates'], period: '/month', category: 'data' },
        { sku: 'DATA-YIELD-BENCH', name: 'Crop Yield Benchmarks', price: 29, badge: '', icon: 'fa-chart-bar', description: 'Regional and national yield benchmarks for comparison.', features: ['Benchmark Comparison', 'Regional Data', 'Historical Trends', 'Improvement Tips'], period: '/month', category: 'data' },
        { sku: 'DATA-INPUTS', name: 'Input Price Tracker', price: 9, badge: '', icon: 'fa-tags', description: 'Track prices of seeds, fertilizer, fuel, and other inputs.', features: ['Price Tracking', 'Trend Analysis', 'Price Alerts', 'Historical Data'], period: '/month', category: 'data' },
        { sku: 'DATA-MARKET-FC', name: 'Market Price Forecasts', price: 49, badge: '', icon: 'fa-chart-line', description: 'AI-powered commodity price forecasts and analysis.', features: ['7-Day Forecast', 'Trend Analysis', 'Trading Signals', 'Export Reports'], period: '/month', category: 'data' },
        { sku: 'DATA-COMPLY', name: 'Compliance Calendar Alerts', price: 19, badge: '', icon: 'fa-calendar-check', description: 'Real-time alerts for compliance deadlines and requirements.', features: ['Deadline Tracking', 'Requirement Alerts', 'Documentation Links', 'Reminder System'], period: '/month', category: 'data' },
        { sku: 'DATA-PEST', name: 'Pest/Disease Heat Maps', price: 29, badge: '', icon: 'fa-bug', description: 'Regional pest and disease activity heat maps.', features: ['Heat Map Visualization', 'Activity Tracking', 'Prediction Models', 'Alert System'], period: '/month', category: 'data' }
      ]
    };
    
    // Cart functionality
    let cart = [];
    
    function loadCart() {
      try {
        const saved = localStorage.getItem('farmfriend_cart');
        if (saved) {
          cart = JSON.parse(saved);
        }
        updateCartUI();
      } catch (e) {
        console.warn('localStorage not available, starting with empty cart');
        cart = [];
        updateCartUI();
      }
    }
    
    function saveCart() {
      try {
        localStorage.setItem('farmfriend_cart', JSON.stringify(cart));
        updateCartUI();
      } catch (e) {
        console.warn('localStorage not available, cart will not persist after refresh');
        updateCartUI();
      }
    }
    
    function addToCart(sku, qty = 1) {
      const allProducts = [...products.hardware, ...products.skills, ...products.services, ...products.support, ...products.cloud, ...products.education, ...products.consulting, ...products.data];
      const product = allProducts.find(p => p.sku === sku);
      if (!product) return;
      
      const existing = cart.find(item => item.sku === sku);
      if (existing) {
        existing.qty += qty;
      } else {
        cart.push({ ...product, qty });
      }
      saveCart();
      showNotification(`Added ${product.name} to cart`);
    }
    
    function removeFromCart(sku) {
      cart = cart.filter(item => item.sku !== sku);
      saveCart();
    }
    
    function updateQty(sku, change) {
      const item = cart.find(i => i.sku === sku);
      if (item) {
        item.qty += change;
        if (item.qty <= 0) removeFromCart(sku);
        else saveCart();
      }
    }
    
    function updateCartUI() {
      const count = cart.reduce((sum, item) => sum + item.qty, 0);
      document.getElementById('cartCount').textContent = count;
      
      const cartItemsEl = document.getElementById('cartItems');
      if (cart.length === 0) {
        cartItemsEl.innerHTML = '<div class="cart-empty"><i class="fas fa-shopping-basket"></i><p>Your cart is empty</p></div>';
      } else {
        cartItemsEl.innerHTML = cart.map(item => `
          <div class="cart-item">
            <div class="cart-item-image"><i class="fas ${item.icon}"></i></div>
            <div class="cart-item-details">
              <div class="cart-item-name">${item.name}</div>
              <div class="cart-item-sku">${item.sku}</div>
              <div class="cart-item-price">$${(item.price * item.qty).toFixed(2)}${item.period || ''}</div>
              <div class="cart-item-qty">
                <button class="qty-btn" onclick="updateQty('${item.sku}', -1)">-</button>
                <span class="qty-value">${item.qty}</span>
                <button class="qty-btn" onclick="updateQty('${item.sku}', 1)">+</button>
              </div>
            </div>
            <button class="cart-item-remove" onclick="removeFromCart('${item.sku}')"><i class="fas fa-trash"></i></button>
          </div>
        `).join('');
      }
      
      const subtotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
      document.getElementById('cartTotal').textContent = `$${subtotal.toFixed(2)}`;
      
      // Update checkout links
      // =====================================================
      // NOTE: Payment processors not yet configured
      // When ready, replace with actual Stripe/PayPal URLs
      //
      // STRIPE: Create a Payment Link at https://dashboard.stripe.com/payment-links
      //         Replace 'your_link' below with your actual Stripe Payment Link URL
      //
      // PAYPAL: Create a PayPal.me link at https://www.paypal.me/yourname
      //        Replace 'your_paypal_username' below with your PayPal username
      // =====================================================
      const totalCents = Math.round(subtotal * 100);
      const cartItems = cart.map(item => `${item.sku} x${item.qty}`).join(', ');
      
      // For now, use email checkout instead of broken payment links
      document.getElementById('stripeCheckout').href = `mailto:contact@farmfriend.com?subject=Order Request&body=Order Total: $${subtotal.toFixed(2)}%0A%0AItems:%0A${cartItems}`;
      document.getElementById('paypalCheckout').href = `mailto:contact@farmfriend.com?subject=Order Request&body=Order Total: $${subtotal.toFixed(2)}%0A%0AItems:%0A${cartItems}`;
      
      // Update button text to reflect email checkout
      document.getElementById('stripeCheckout').innerHTML = '<i class="fas fa-envelope"></i> Email Your Order';
      document.getElementById('paypalCheckout').innerHTML = '<i class="fas fa-envelope"></i> Email Your Order';
    }
    
    function toggleCart() {
      document.getElementById('cartSidebar').classList.toggle('open');
    }
    
    function toggleMobileMenu() {
      document.getElementById('mobileMenu').classList.toggle('open');
      document.getElementById('mobileMenuOverlay').classList.toggle('open');
    }
    
    function closeMobileMenu() {
      document.getElementById('mobileMenu').classList.remove('open');
      document.getElementById('mobileMenuOverlay').classList.remove('open');
    }
      document.body.style.overflow = document.getElementById('mobileMenu').classList.contains('open') ? 'hidden' : '';
    }
    
    function showNotification(message) {
      const notif = document.getElementById('cartNotification');
      document.getElementById('notificationText').textContent = message;
      notif.classList.add('show');
      setTimeout(() => notif.classList.remove('show'), 3000);
    }
    
    // Product modal
    function showProductModal(sku) {
      const allProducts = [...products.hardware, ...products.skills, ...products.services, ...products.support, ...products.cloud, ...products.education, ...products.consulting, ...products.data];
      const product = allProducts.find(p => p.sku === sku);
      if (!product) return;
      
      const modal = document.getElementById('modalContent');
      modal.innerHTML = `
        <div class="modal-header">
          <button class="modal-close" onclick="closeModal()"><i class="fas fa-times"></i></button>
          ${product.badge ? `<span class="modal-badge">${product.badge}</span>` : ''}
          <div class="modal-sku">${product.sku}</div>
          <h2 class="modal-title">${product.name}</h2>
        </div>
        <div class="modal-image"><i class="fas ${product.icon}"></i></div>
        <div class="modal-body">
          <p class="modal-description">${product.description}</p>
          <div class="modal-features">
            <h4>Key Features</h4>
            <ul>${product.features.map(f => `<li>${f}</li>`).join('')}</ul>
          </div>
        </div>
        <div class="modal-footer">
          <div class="modal-price">$${product.price}<span style="font-size: 1rem; font-weight: 400; color: var(--text-muted); margin-left: 0.5rem;">${product.period || ''}</span></div>
          <div class="modal-actions">
            <button class="btn-modal-close" onclick="closeModal()">Close</button>
            <button class="btn-modal-add" onclick="addToCart('${product.sku}'); closeModal();">Add to Cart</button>
          </div>
        </div>
      `;
      document.getElementById('productModal').classList.add('open');
    }
    
    function closeModal() {
      document.getElementById('productModal').classList.remove('open');
    }
    
    // Close modal on overlay click
    document.getElementById('productModal').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });
    
    // Close modal on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
    });
    
    // Render products
    function renderProducts() {
      Object.keys(products).forEach(category => {
        const grid = document.getElementById(`${category}-grid`);
        if (!grid) return;
        
        grid.innerHTML = products[category].map(product => `
          <div class="product-card reveal" onclick="showProductModal('${product.sku}')">
            <div class="product-image">
              ${product.badge ? `<span class="product-badge">${product.badge}</span>` : ''}
              <i class="fas ${product.icon}"></i>
            </div>
            <div class="product-content">
              <div class="product-sku">${product.sku}</div>
              <h3 class="product-name">${product.name}</h3>
              <p class="product-description">${product.description}</p>
              <div class="product-features">
                ${product.features.slice(0, 3).map(f => `<span class="feature-tag">${f}</span>`).join('')}
              </div>
              <div class="product-footer">
                <div class="product-price">$${product.price}<span class="product-price-period">${product.period || ''}</span></div>
                <button class="btn-add" onclick="event.stopPropagation(); addToCart('${product.sku}')">Add to Cart</button>
              </div>
            </div>
          </div>
        `).join('');
      });
    }
    
    function scrollToSection(id) {
      const el = document.getElementById(id);
      if (!el) {
        console.warn(`Section "${id}" not found`);
        return;
      }
      
      // Account for fixed header height
      const headerOffset = 80;
      const elementPosition = el.getBoundingClientRect().top;
      const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
      
      try {
        window.scrollTo({
          top: offsetPosition,
          behavior: 'smooth'
        });
      } catch (e) {
        // Fallback for older browsers
        window.scrollTo(0, offsetPosition);
      }
      
      // Close mobile menu if open
      if (window.innerWidth <= 1024) {
        closeMobileMenu();
      }
    }
    
    // Scroll reveal
    function initScrollReveal() {
      const reveals = document.querySelectorAll('.reveal');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          }
        });
      }, { threshold: 0.1 });
      
      reveals.forEach(el => observer.observe(el));
    }
    
    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
      loadCart();
      renderProducts();
      initScrollReveal();
      document.getElementById('cartBtn').addEventListener('click', toggleCart);
      
      // Email signup form
      const emailForm = document.getElementById('emailSignupForm');
      if (emailForm) {
        emailForm.addEventListener('submit', function(e) {
          e.preventDefault();
          const emailInput = this.querySelector('#newsletterEmail');
          const email = emailInput.value;
          
          // RFC 5322 compliant email validation
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          
          if (!email || !emailRegex.test(email)) {
            showNotification('Please enter a valid email address');
            emailInput.focus();
            return;
          }
          
          // Simulate API call - replace with actual Mailchimp/ConvertKit integration
          try {
            const subscribers = JSON.parse(localStorage.getItem('newsletter_subscribers') || '[]');
            if (subscribers.includes(email)) {
              showNotification('This email is already subscribed!');
              return;
            }
            
            subscribers.push(email);
            localStorage.setItem('newsletter_subscribers', JSON.stringify(subscribers));
            
            // Show success message in the page (not just notification)
            const successMsg = document.createElement('div');
            successMsg.style.cssText = 'background: var(--brand-primary); color: white; padding: 1rem; border-radius: 8px; margin-top: 1rem; text-align: center; font-size: 0.95rem;';
            successMsg.innerHTML = '<i class="fas fa-check-circle"></i> Thanks for subscribing! Check your inbox for confirmation.';
            emailForm.insertAdjacentElement('afterend', successMsg);
            emailForm.style.display = 'none';
          } catch (err) {
            showNotification('Error saving subscription. Please try again.');
          }
          
          this.reset();
        });
      }
      
      // Search functionality
      const searchInput = document.getElementById('searchInput');
      if (searchInput) {
        searchInput.addEventListener('input', function(e) {
          const query = e.target.value.toLowerCase();
          if (query.length < 2) {
            // Show all products if search is empty
            document.querySelectorAll('.product-card').forEach(card => card.style.display = '');
            return;
          }
          // Hide/show products based on name match
          document.querySelectorAll('.product-card').forEach(card => {
            const name = card.querySelector('.product-name').textContent.toLowerCase();
            const sku = card.querySelector('.product-sku').textContent.toLowerCase();
            const desc = card.querySelector('.product-description').textContent.toLowerCase();
            if (name.includes(query) || sku.includes(query) || desc.includes(query)) {
              card.style.display = '';
            } else {
              card.style.display = 'none';
            }
          });
        });
      }
    });
  </script>
</body>
</html>
